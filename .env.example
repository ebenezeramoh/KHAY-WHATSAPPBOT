# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
# From your Meta Developer App > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Any secret string you choose — must match what you enter in Meta Developer Console
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_123

# ─── Admin Notifications (optional) ──────────────────────────────────────────
# Your own WhatsApp number to receive new order alerts (international format, no +)
ADMIN_WHATSAPP_NUMBER=233201234567

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
